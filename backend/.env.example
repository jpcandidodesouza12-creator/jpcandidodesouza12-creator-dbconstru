# ─────────────────────────────────────────────
# Dumb Construtor — Backend Environment
# Copy to .env and fill in values
# ─────────────────────────────────────────────

# Server
NODE_ENV=development
PORT=4000

# ─── Neon Database ────────────────────────────
# From: console.neon.tech → your project → Connection Details
# Use "Pooled connection" for DATABASE_URL (PgBouncer)
# Use "Direct connection" for DIRECT_URL (migrations)
DATABASE_URL="postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require&pgbouncer=true"
DIRECT_URL="postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require"

# ─── JWT ─────────────────────────────────────
# Generate strong secrets: openssl rand -hex 64
JWT_SECRET="CHANGE_ME_GENERATE_STRONG_SECRET_64_CHARS_MIN"
JWT_EXPIRES_IN="15m"
REFRESH_TOKEN_SECRET="CHANGE_ME_ANOTHER_STRONG_SECRET_64_CHARS_MIN"
REFRESH_TOKEN_EXPIRES_IN="7d"

# ─── CORS ────────────────────────────────────
# Frontend URLs allowed (comma-separated)
CORS_ORIGINS="http://localhost:3000,https://dumb-construtor.vercel.app"

# ─── Rate Limiting ───────────────────────────
RATE_LIMIT_WINDOW_MS=900000   # 15 min
RATE_LIMIT_MAX=100            # requests per window
AUTH_RATE_LIMIT_MAX=10        # stricter for auth routes
